      },
      {
        "type": "toggle",
        "messageKey": "Hour24Time",
        "label": "Use 24-hour numbers",
        "description": "Shows hours as 0-23 instead of 1-12. Only applies when numbers are enabled.",
        "defaultValue": false
      }
    ]
  },
  {
    "type": "section",
    "items": [
      {
        "type": "heading",
        "defaultValue": "Goals"
      },
      {
        "type": "text",
        "defaultValue": "Steps and sleep turn green once the goal is met. Heart rate is colored by zone automatically. Color watches only."
      },
      {
        "type": "input",
        "messageKey": "TargetSteps",
        "label": "Steps goal",
        "defaultValue": "10000",
        "attributes": { "type": "number", "min": "1" }
